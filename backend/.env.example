# Copy to backend/.env (gitignored). Without a key the tutor runs in dev mode
# (canned coaching) so the app still works end-to-end.
GROQ_API_KEY=

# Postgres. Empty = in-memory store (sessions/imports won't survive a restart).
DATABASE_URL=

# Optional model overrides:
# COACH_MODEL=llama-3.3-70b-versatile
# FAST_MODEL=llama-3.1-8b-instant
# USE_FAST_MODEL=false
# MAX_TOKENS_PER_SESSION=20000

# Optional Spotify Premium play-along (needs a Spotify developer app):
# SPOTIFY_ENABLED=true
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://localhost:8000/api/spotify/callback
